# ─────────────────────────────────────────────────────────────────────────────
# Website Centralizer — Environment Variables
# Copy to .env.local for local development
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── TinaCMS (self-hosted / local) ─────────────────────────────────────────────
# Leave blank for local filesystem mode.
# For Tina Cloud: get these from app.tina.io
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
NEXT_PUBLIC_TINA_GRAPHQL_URL=http://localhost:4001/graphql

# ── GoHighLevel ───────────────────────────────────────────────────────────────
# GTM Container ID or GHL Location tracking ID
NEXT_PUBLIC_GHL_LOCATION_ID=
# Your GHL sub-account location ID
NEXT_PUBLIC_GHL_LOCATION=

# ── n8n Automation (Server A) ─────────────────────────────────────────────────
# Base URL of n8n instance on Server A
NEXT_PUBLIC_N8N_BASE_URL=http://SERVER_A_IP:5678
# Optional: HMAC shared secret for webhook signature verification
N8N_WEBHOOK_SECRET=

# ── Analytics (optional) ──────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
